# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False

# Database
# By default the app tries to connect to the Postgres values below at startup.
# If that connection fails (wrong credentials, unreachable host, etc.) it
# automatically falls back to a local SQLite file at backend/db.sqlite3 —
# no values below are required for local-only development.
DB_NAME=postgres
DB_USER=postgres
DB_PWD=your-database-password-here
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432

# CORS Settings (optional)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
